OTHER GIT FEATURES
git config --global user.name "[firstname lastname]" – Set username for all repositories
git config --global user.email "[valid-email]" – Set email for all repositories
git config --global color.ui auto – Enable colored Git output
git init – Initialize a new Git repository
git clone [url] – Clone a repository from a remote URL
git status – Show status of working directory and staging area
git add [file] – Add file(s) to staging area
git reset [file] – Unstage a file but keep its changes
git diff – Show changes not yet staged
git diff --staged – Show changes staged but not committed
git commit -m "[message]" – Commit staged changes with a message
git branch – List all branches
git branch [branch-name] – Create a new branch
git checkout [branch-name] – Switch to another branch
git merge [branch] – Merge a branch into the current branch
git log – Show commit history
git log branchB..branchA – Show commits in branchA not in branchB
git log --follow [file] – Show history of a file (including renames)
git diff branchB...branchA – Show differences between branches
git show [SHA] – Show details of a specific commit
git remote add [alias] [url] – Add a remote repository
git fetch [alias] – Fetch changes from remote repository
git merge [alias]/[branch] – Merge remote branch into current branch
git push [alias] [branch] – Push commits to remote repository
git pull – Fetch and merge changes from remote
git rm [file] – Delete file and stage the removal
git mv [old-path] [new-path] – Move or rename a file
git log --stat -M – Show commit logs with file movement details
logs/ *.notes pattern*/ – Example patterns for .gitignore
git config --global core.excludesfile [file] – Set global ignore file
git rebase [branch] – Reapply commits on top of another branch
git reset --hard [commit] – Reset repository to a specific commit (destructive)
git stash – Temporarily save uncommitted changes
git stash list – List all stashed changes
git stash pop – Apply and remove latest stash
git stash drop – Delete a stash
