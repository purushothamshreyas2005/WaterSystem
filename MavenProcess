PAYROLL CHECKER
App.java
package com.example;

public class App {

    public double calculateSalary(double basic) {
        double hra = 0.2 * basic;
        double da = 0.1 * basic;
        return basic + hra + da;
    }

    public static void main(String[] args) {
        App app = new App();
        System.out.println(app.calculateSalary(10000));
    }
}

AppTest.java
package com.example;

import org.junit.Test;
import static org.junit.Assert.*;

public class AppTest {

    @Test
    public void testSalary() {
        App app = new App();
        assertEquals(13000, app.calculateSalary(10000), 0.01);
    }
}
