ATTENDANCE CHECKER
App.java
package com.example;

public class App {

    public String checkAttendance(int attended, int total) {
        double percentage = (attended * 100.0) / total;

        if (percentage >= 75) return "Eligible";
        else return "Not Eligible";
    }

    public static void main(String[] args) {
        App app = new App();
        System.out.println(app.checkAttendance(60, 80));
    }
}

AppTest.java
package com.example;

import org.junit.Test;
import static org.junit.Assert.*;

public class AppTest {

    @Test
    public void testEligible() {
        App app = new App();
        assertEquals("Eligible", app.checkAttendance(60, 80));
    }

    @Test
    public void testNotEligible() {
        App app = new App();
        assertEquals("Not Eligible", app.checkAttendance(40, 80));
    }
}
